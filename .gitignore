# This file is used to ignore files which are generated in working
# directory when running Gradle. For more details check
# http://docs.gradle.org/current/userguide/build_environment.html

# Gradle files
.gradle/
build/
gradle/

# Local configuration file (sdk path, etc)
local.properties

# Log/OS Files
*.log

# Gradle files
.gradle/
build/

# IDEA
.idea/
*.iml
*.iws
*.ipr

# THE REST
.DS_Store

# Unity files and folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
Assets/AssetStoreTools*
[Cc]onverted/

# Unity meta files
*.meta

# VS
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Covers JetBrains IDEs: IntelliJ, RubyMine, PhpStorm, AppCode, PyCharm, CLion, Android Studio, WebStorm and Rider
# Reference: https://intellij-support.jetbrains.com/hc/en-us/articles/206544839
.idea/
*.iml
*.iws
*.ipr
*.ods

# User-specific stuff
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# Gradle and Maven with auto-import
.idea/modules.xml
.idea/*.iml
.idea/modules

# Folders to ignore
.vs/
.vscode/
Library/
Temp/
Obj/
Builds/
UserSettings/

# Files to ignore
*.suo
*.user
*.userosscache
*.sln.docstates
.DS_Store
*.swp
*~

# Generated files
ProjectSettings/ProjectVersion.txt

# Rider cache/options directory
.idea_modules/

# Personal IDE extensions
.idea/inspectionProfiles/
